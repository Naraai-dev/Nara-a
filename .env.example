# Port & Host (standard configuration, do not modify)
PORT=3000

# Resend API Key for Email Routing
RESEND_API_KEY=""

# Supabase Cloud Integration (Database, Auth, and Storage)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Client-facing variables (for React + Vite)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"

# Production API URL (Used by Netlify frontend to communicate with Railway backend)
VITE_API_URL="https://your-backend.railway.app"

# Gemini API Key (Server-side only secret)
GEMINI_API_KEY=""
